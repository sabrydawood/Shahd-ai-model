# Foundry configuration. Bun loads .env automatically (no dotenv). Copy to .env and fill in.

# Postgres. When DATABASE_URL is set, the foundry scripts use Postgres BY DEFAULT (no --Store needed),
# so ingested data persists and shows up in the dashboard.
DATABASE_URL=postgres://shahd:shahd@localhost:5432/shahd

# GitHub token — raises the API + tarball rate limit from 60 to 5000 req/hr (recommended for
# whole-repo ingestion). Create at: GitHub -> your avatar -> Settings -> Developer settings ->
# Personal access tokens -> Tokens (classic) -> Generate. No scope needed for public repos;
# enable 'repo' for private ones.
GITHUB_TOKEN=

# Brave Search API key — enables general web-search ingestion (isolated Raw tier). Optional.
BRAVE_API_KEY=

# Default web/repo search query (override per run with --Query=...).
FOUNDRY_QUERY=language:typescript license:mit stars:>500

# Own repositories to ingest with foundry:ingest-repos, comma-separated (override with --Repos=...).
FOUNDRY_REPOS=.

# Force a store: memory | postgres. Default: postgres when DATABASE_URL is set, else memory.
# FOUNDRY_STORE=postgres

# Named checkpoint to load as the live chat model on dashboard startup. Default: Seed.
# FOUNDRY_CHECKPOINT_NAME=Seed

# File-store fallback path for the checkpoint above, used only when Postgres has no matching
# checkpoint (or DATABASE_URL is unset). Default: Checkpoints/Foundry.ckpt.
# FOUNDRY_CHECKPOINT=Checkpoints/Foundry.ckpt

# Self-consistency at serving time: the chat model answers a turn N times (different sampling
# seeds) and the majority-voted answer wins. Default: 1 (off). Set N>1 (e.g. 5) to enable — needs
# Temperature>0 to diverge.
# SHAHD_SELF_CONSISTENCY=1
